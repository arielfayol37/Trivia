DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider for authoring/judging:
# - sample: deterministic local generator, no API calls
# - openai: OpenAI SDK
# - anthropic: Anthropic SDK
# - auto: prefer OpenAI if configured, else Anthropic, else sample
LLM_PROVIDER=sample

OPENAI_API_KEY=
OPENAI_AUTHOR_MODEL=
OPENAI_JUDGE_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_AUTHOR_MODEL=
ANTHROPIC_JUDGE_MODEL=

# Local dev uses SQLite unless DATABASE_ENGINE=postgres.
DATABASE_ENGINE=sqlite

# Optional Postgres settings for Docker/desktop hosting.
POSTGRES_DB=trivia
POSTGRES_USER=trivia
POSTGRES_PASSWORD=trivia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0

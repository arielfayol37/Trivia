DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0

# Local Docker smoke test:
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
#
# Cloudflare/desktop hosting:
# DJANGO_ALLOWED_HOSTS=trivia.example.com,localhost,127.0.0.1,[::1]
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Same-origin Caddy hosting does not need Vite origins. Add your public HTTPS origin
# when exposing through Cloudflare Tunnel.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# LLM provider for authoring/judging:
# - sample: deterministic local generator, no API calls
# - openai: OpenAI SDK
# - anthropic: Anthropic SDK
# - auto: prefer OpenAI if configured, else Anthropic, else sample
LLM_PROVIDER=sample

OPENAI_API_KEY=
OPENAI_AUTHOR_MODEL=
OPENAI_JUDGE_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_AUTHOR_MODEL=
ANTHROPIC_JUDGE_MODEL=

DATABASE_ENGINE=postgres
POSTGRES_DB=trivia
POSTGRES_USER=trivia
POSTGRES_PASSWORD=replace-with-a-real-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CHANNEL_LAYER_BACKEND=redis

SESSION_LOBBY_COUNTDOWN_S=5
SESSION_ALL_SUBMITTED_ADVANCE_DELAY_S=4
SESSION_TIMER_ADVANCE_GRACE_S=4
SESSION_PRESENCE_STALE_AFTER_S=45
